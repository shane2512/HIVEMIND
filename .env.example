# Hedera Account
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.XXXXX
HEDERA_OPERATOR_KEY=302e...
HEDERA_EVM_PRIVATE_KEY=0x...   # EVM-compatible key from Hedera Portal

# LLM Provider (choose one)
# Set LLM_PROVIDER to one of: openrouter, groq, deepseek, ollama
LLM_PROVIDER=ollama

# Option A (recommended free-tier): OpenRouter + Mistral free model
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=mistralai/mistral-small-3.1-24b-instruct:free

# Option B: Groq (free tier)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Option C: DeepSeek direct API
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Option D (fully local): Ollama + Phi3.5
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=phi3.5
PLANNER_MODEL=phi3.5
LLM_TIMEOUT_MS=25000
LLM_REASONING_DISABLED=false

# HCS Topics (auto-populated by agents/shared/setup-topics.js)
HCS_REGISTRY_TOPIC=
HCS_TASK_TOPIC=
HCS_ATTESTATION_TOPIC=
HCS_REPORT_TOPIC=
HCS_BLACKLIST_TOPIC=

# Deployed Contracts (auto-populated by contracts/deploy-*.js)
PIPE_TOKEN_ID=
PIPELINE_NFT_TOKEN_ID=
PIPE_ESCROW_ADDRESS=
PIPE_TOKEN_DECIMALS=6
ESCROW_TIMEOUT_SECONDS=600

# Watcher Agent Config
WATCHER_MIN_LIQUIDITY_HBAR=100
WATCHER_POLL_INTERVAL_MS=5000
WATCHER_CREATOR_WALLET_MIN_AGE_HOURS=24
WATCHER_EXCLUDE_OPERATOR_CREATOR=false

# Plumber Agent Config
PLUMBER_ROUTING_FEE_PERCENT=8
PLUMBER_NFT_MINT_THRESHOLD=10
PLUMBER_PLANNER_MODE=llm

# Goal Agent Config
GOAL_AGENT_PIPE_BALANCE=1000
GOAL_AGENT_RESERVE_PERCENT=5
TASK_TIMEOUT_MINUTES=10

# Dashboard (Vite — prefix with VITE_)
VITE_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com
VITE_HASHSCAN_URL=https://hashscan.io/testnet
VITE_HCS_REGISTRY_TOPIC=
VITE_HCS_TASK_TOPIC=
VITE_HCS_ATTESTATION_TOPIC=
VITE_HCS_REPORT_TOPIC=
VITE_HCS_BLACKLIST_TOPIC=

# Runtime APIs
MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com
HEDERA_JSON_RPC_URL=https://testnet.hashio.io/api
